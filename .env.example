# X Engine — environment variables
#
# TELEGRAM_BOT_TOKEN is the only value you need to set manually before
# starting the bot. Everything else is saved automatically during the
# Telegram onboarding wizard (/setup).

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather

# Set automatically by /setup — do not edit by hand:
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
# X credentials are NOT stored here — twikit saves a session cookie to cookies.json
